  description="The questions to ask, the red flags to watch for, and the process that protects you when hiring a contractor for your Utah home remodel."
  schema={schema}
>

  <!-- HERO -->
  <section class="relative py-20 md:py-28 overflow-hidden" style="background: var(--color-navy)">
    <div class="container-site relative z-10">
      <div class="max-w-2xl">
