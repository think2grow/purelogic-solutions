---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ui/ContactForm.tsx';
---

<BaseLayout
  title="Get a Free Estimate | Pure Logic Solutions Utah"
  description="Request a free, no-obligation estimate from Pure Logic Solutions — Utah's trusted general contractor. Kitchen remodels, bathroom renovations, basement finishing, and more across the Wasatch Front."
>

  <!-- ═══════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════ -->
  <section class="relative py-20 md:py-28 overflow-hidden" style="background: var(--color-navy)">
    <div class="absolute inset-0 z-0 opacity-5" style="background-image: linear-gradient(rgba(60,225,225,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(60,225,225,0.3) 1px, transparent 1px); background-size: 60px 60px;"></div>
    <div class="container-site relative z-10">
      <div class="max-w-2xl">
        <span class="section-label-light">No Obligation. No Pressure.</span>
        <h1 class="text-4xl md:text-5xl font-black text-white mb-4 leading-tight">
          Get a Free <span style="color: var(--color-cyan)">Estimate</span>
        </h1>
        <p class="text-lg leading-relaxed" style="color: rgba(255,255,255,0.72)">
          Fill out the form and Jared will personally reach out within 24 hours to discuss your project. No sales scripts. No pressure. Just an honest conversation about what it would take to do it right.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       MAIN — form + sidebar on dark background
       ═══════════════════════════════════════════════════════ -->
  <section class="section-padding" style="background: var(--color-navy)">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12 items-start">

        <!-- FORM COLUMN -->
        <div class="lg:col-span-3 reveal-left">
          <ContactForm client:load />
        </div>

        <!-- INFO SIDEBAR -->
        <div class="lg:col-span-2 reveal-right">

          <!-- What Happens Next -->
          <div class="mb-10">
            <h2 class="text-xl font-black mb-5 text-white" style="font-family: var(--font-heading)">What Happens Next</h2>
            <div class="flex flex-col gap-5">
              {[
                { step: '01', title: 'We Review Your Request', desc: 'Jared personally reads every submission. You will hear back within 24 hours — usually same day.' },
                { step: '02', title: 'Discovery Call', desc: 'A quick 15–30 minute call to understand your vision, timeline, and goals before we ever step foot on site.' },
                { step: '03', title: 'Free Site Visit', desc: 'We come to you — measuring, photographing, and truly understanding your project before a single number is quoted.' },
                { step: '04', title: 'Detailed Written Estimate', desc: 'You receive a fully itemized, line-by-line estimate. No vague numbers. No surprises later.' },
              ].map((item) => (
                <div class="flex gap-4">
                  <div class="flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center text-xs font-black" style="background: rgba(60,225,225,0.12); border: 1px solid rgba(60,225,225,0.3); color: var(--color-cyan); font-family: var(--font-heading)">
                    {item.step}
                  </div>
                  <div>
                    <p class="font-bold text-sm mb-1 text-white" style="font-family: var(--font-heading)">{item.title}</p>
                    <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.55)">{item.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div style="border-top: 1px solid rgba(60,225,225,0.12); margin-bottom: 2rem;"></div>

          <!-- Direct Contact -->
          <div class="mb-10">
            <h2 class="text-xl font-black mb-5 text-white" style="font-family: var(--font-heading)">Prefer to Call or Email?</h2>
            <div class="flex flex-col gap-4">
              <a href="tel:+18019058175"
                class="flex items-center gap-4 p-4 rounded-lg transition-all duration-200"
                style="background: rgba(255,255,255,0.04); border: 1px solid rgba(60,225,225,0.15);"
                onmouseover="this.style.background='rgba(60,225,225,0.08)'; this.style.borderColor='rgba(60,225,225,0.35)'"
                onmouseout="this.style.background='rgba(255,255,255,0.04)'; this.style.borderColor='rgba(60,225,225,0.15)'">
                <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style="background: rgba(60,225,225,0.12)">
                  <svg class="w-5 h-5" style="color: var(--color-cyan)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-bold uppercase tracking-widest mb-0.5" style="color: var(--color-cyan); font-family: var(--font-heading)">Call Direct</p>
                  <p class="font-black text-white" style="font-family: var(--font-heading)">(801) 905-8175</p>
                  <p class="text-xs" style="color: rgba(255,255,255,0.45)">Mon–Fri 7am–6pm · Sat 8am–4pm</p>
                </div>
              </a>

              <a href="mailto:Purelogicsolutionsutah@gmail.com"
                class="flex items-center gap-4 p-4 rounded-lg transition-all duration-200"
                style="background: rgba(255,255,255,0.04); border: 1px solid rgba(60,225,225,0.15);"
                onmouseover="this.style.background='rgba(60,225,225,0.08)'; this.style.borderColor='rgba(60,225,225,0.35)'"
                onmouseout="this.style.background='rgba(255,255,255,0.04)'; this.style.borderColor='rgba(60,225,225,0.15)'">
                <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style="background: rgba(60,225,225,0.12)">
                  <svg class="w-5 h-5" style="color: var(--color-cyan)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-bold uppercase tracking-widest mb-0.5" style="color: var(--color-cyan); font-family: var(--font-heading)">Email Us</p>
                  <p class="font-black text-sm text-white break-all" style="font-family: var(--font-heading)">Purelogicsolutionsutah@gmail.com</p>
                  <p class="text-xs" style="color: rgba(255,255,255,0.45)">We respond within 24 hours</p>
                </div>
              </a>
            </div>
          </div>

          <div style="border-top: 1px solid rgba(60,225,225,0.12); margin-bottom: 2rem;"></div>

          <!-- Trust Signals -->
          <div>
            <h2 class="text-xl font-black mb-5 text-white" style="font-family: var(--font-heading)">Why Homeowners Choose Jared</h2>
            <div class="flex flex-col gap-3">
              {[
                'Utah Licensed & Insured · #14253923-5501',
                'Serving Ogden to Santaquin, Tooele to Park City',
                'Free, itemized written estimates — no vague numbers',
                'Clear communication from first call to final walkthrough',
                'We respond within 24 hours, guaranteed',
                '"Would we put it in our house?" — our standard on every project',
              ].map((item) => (
                <div class="flex items-start gap-3 text-sm" style="color: rgba(255,255,255,0.65)">
                  <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: var(--color-cyan)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                  </svg>
                  <span>{item}</span>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

</BaseLayout>
