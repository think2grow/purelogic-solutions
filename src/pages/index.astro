---
import BaseLayout from '../layouts/BaseLayout.astro';
import TypewriterHero from '../components/ui/TypewriterHero.tsx';
import AnimatedStats from '../components/ui/AnimatedStats.tsx';
import MagneticButton from '../components/ui/MagneticButton.tsx';
import ProjectEstimator from '../components/ui/ProjectEstimator.tsx';
import ProcessTimeline from '../components/ui/ProcessTimeline.tsx';

const services = [
  { title: 'Kitchen Remodeling', description: 'Transform the heart of your home. Custom cabinetry, quartz countertops, tile backsplash, and full layout redesigns — done right, on time, on budget.', href: '/services/kitchen-remodeling', stat: 'Most Requested', iconPath: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
  { title: 'Bathroom Remodeling', description: 'Create a spa-like retreat in your own home. We handle tile work, plumbing, vanities, walk-in showers, and every detail in between.', href: '/services/bathroom-remodeling', stat: 'High ROI', iconPath: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' },
  { title: 'Basement Finishing', description: 'Unlock the potential beneath your feet. We turn unfinished basements into fully livable spaces — home theaters, gyms, guest suites, and more.', href: '/services/basement-finishing', stat: 'Best Value Add', iconPath: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
  { title: 'Home Additions', description: 'Love your neighborhood but need more space? We design and build seamless additions that blend perfectly with your existing home.', href: '/services/home-additions', stat: 'Expand In Place', iconPath: 'M12 4v16m8-8H4' },
  { title: 'Custom Home Builds', description: 'Build the home you have always envisioned, from the ground up. We manage every phase with the same transparency and precision we bring to every project.', href: '/services/custom-homes', stat: 'Full Service', iconPath: 'M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z' },
  { title: 'Whole Home Remodels', description: 'When a single room is not enough. We coordinate complete home transformations — managing every trade, every timeline, and every detail.', href: '/services/whole-home-remodels', stat: 'Full Transformation', iconPath: 'M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z' },
];

const commitments = [
  { title: 'Clear Communication', desc: 'Regular updates via your preferred method. No silence. No chasing us down.', iconPath: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z' },
  { title: 'Structured Planning', desc: 'Every project runs on systems, not guesswork. Documented scope. Locked timelines.', iconPath: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4' },
  { title: 'On Time, On Budget', desc: 'Itemized estimates. Transparent change orders. No surprise invoices at the end.', iconPath: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
  { title: 'Respect for Your Home', desc: 'Daily cleanup. Protective measures. We treat your home as if it were our own.', iconPath: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
];
---

<BaseLayout
  title="Pure Logic Solutions | Premium Home Remodeling & General Contractor Utah"
  description="Utah's trusted general contractor for kitchen remodeling, bathroom renovation, basement finishing, home additions, and custom homes. Serving the Wasatch Front from Ogden to Santaquin. Licensed #14253923-5501."
>

  <!-- ═══════════════════════════════════════════════════════
       HERO — Full viewport, dark navy bg, typewriter headline
       ═══════════════════════════════════════════════════════ -->
  <section class="relative min-h-screen flex items-center overflow-hidden" style="background: var(--color-navy)">
    <!-- Background image with overlay -->
    <div class="absolute inset-0 z-0">
      <img
        src="/images/kitchen-hero.jpg"
        alt="Premium kitchen remodel by Pure Logic Solutions Utah"
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 hero-overlay"></div>
    </div>

    <!-- Subtle grid pattern overlay -->
    <div class="absolute inset-0 z-0 opacity-5" style="background-image: linear-gradient(rgba(60,225,225,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(60,225,225,0.3) 1px, transparent 1px); background-size: 60px 60px;"></div>

        <div class="container-site relative z-10 py-20 md:py-36">
      <div class="max-w-3xl">
        <!-- Trust badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-8 text-xs font-bold tracking-widest uppercase reveal" style="background: rgba(60,225,225,0.12); border: 1px solid rgba(60,225,225,0.35); color: var(--color-cyan)">
          <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          Utah Licensed &amp; Insured &middot; #14253923-5501
        </div>

        <!-- Headline with typewriter -->
        <h1 class="text-5xl md:text-7xl font-black text-white mb-6 leading-none tracking-tight reveal" style="font-family: var(--font-heading)">
          We Build It<br/>
          <TypewriterHero client:load />
        </h1>

        <p class="text-lg md:text-xl mb-10 max-w-xl leading-relaxed reveal" style="color: rgba(255,255,255,0.80)">
          Premium home remodeling and general contracting across the Wasatch Front. No shortcuts. No surprises. Expert craftsmanship and clear communication from start to finish.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mb-12 reveal">
          <MagneticButton href="/contact" variant="primary" client:load>
            Get a Free Estimate
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </MagneticButton>
          <MagneticButton href="tel:+18019058175" variant="ghost" client:load>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            Call (801) 905-8175
          </MagneticButton>
        </div>

        <!-- Social proof row -->
        <div class="flex flex-wrap items-center gap-6 reveal">
          <div class="flex items-center gap-2 text-sm" style="color: rgba(255,255,255,0.75)">
            <svg class="w-4 h-4 flex-shrink-0" style="color: var(--color-cyan)" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            Fully Licensed &amp; Insured
          </div>
          <div class="w-px h-4" style="background: rgba(255,255,255,0.2)"></div>
          <div class="flex items-center gap-2 text-sm" style="color: rgba(255,255,255,0.75)">
            <svg class="w-4 h-4 flex-shrink-0" style="color: var(--color-cyan)" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            Wasatch Front, Utah
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 opacity-60">
      <span class="text-xs tracking-widest uppercase" style="color: rgba(255,255,255,0.5); font-family: var(--font-heading)">Scroll</span>
      <div class="w-px h-10" style="background: linear-gradient(to bottom, rgba(60,225,225,0.6), transparent)"></div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       ANIMATED STATS BAR — count-up on scroll
       ═══════════════════════════════════════════════════════ -->
  <section style="background: var(--color-navy); border-bottom: 1px solid rgba(60,225,225,0.12)">
    <div class="container-site">
      <AnimatedStats client:visible />
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       FOUNDER / VIDEO — light bg, dark text, high contrast
       ═══════════════════════════════════════════════════════ -->
  <section class="section-padding" style="background: var(--color-off-white)">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
        <!-- Real Jared video embed -->
        <div class="reveal-left">
          <div class="rounded-xl overflow-hidden shadow-2xl" style="position: relative; padding-top: 56.25%;">
            <iframe
              src="https://customer-dn4rv9s0dbwshimy.cloudflarestream.com/0846b02a586a6598b14f2f59a5822638/iframe?preload=true&poster=https%3A%2F%2Fcustomer-dn4rv9s0dbwshimy.cloudflarestream.com%2F0846b02a586a6598b14f2f59a5822638%2Fthumbnails%2Fthumbnail.jpg%3Ftime%3D19s%26height%3D600"
              loading="lazy"
              style="border: none; position: absolute; top: 0; left: 0; height: 100%; width: 100%;"
              allow="accelerometer; gyroscope; autoplay; encrypted-media; picture-in-picture;"
              allowfullscreen="true"
              title="Jared Bayless — Founder of Pure Logic Solutions"
            ></iframe>
          </div>
        </div>

        <!-- Text — all dark text on light background -->
        <div class="reveal-right">
          <span class="section-label">Meet Jared Bayless</span>
          <h2 class="text-3xl md:text-4xl font-black mb-4 leading-tight" style="color: var(--color-navy)">
            Built on a Standard Most<br/>Contractors Won't Commit To
          </h2>
          <div class="divider-cyan"></div>
          <p class="text-base mb-5 leading-relaxed" style="color: var(--color-body-text)">
            Pure Logic Solutions was founded on a single question that drives every project: <strong style="color: var(--color-navy)">"Would we put it in our house?"</strong> If the answer is no, we do not do it. That standard shapes every material recommendation, every subcontractor we hire, and every detail we sign off on.
          </p>
          <p class="text-base mb-8 leading-relaxed" style="color: var(--color-body-text)">
            Jared is a husband, father of three, and a local Utah builder who believes that construction can be structured, clear, and professional. No disappearing acts. No overpromises. No surprises on your invoice.
          </p>
          <blockquote class="border-l-4 pl-5 mb-8" style="border-color: var(--color-cyan)">
            <p class="text-base italic leading-relaxed" style="color: var(--color-body-text)">
              "If you want the cheapest bid, we may not be the right fit. If you want smart execution and a team that treats your home like their own — let's talk."
            </p>
            <footer class="mt-2 text-sm font-bold" style="color: var(--color-navy); font-family: var(--font-heading)">— Jared Bayless, Founder</footer>
          </blockquote>
          <a href="/about" class="btn-secondary">
            Our Story
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       SERVICES GRID — white bg, dark cards
       ═══════════════════════════════════════════════════════ -->
  <section class="section-padding" style="background: white">
    <div class="container-site">
      <div class="text-center mb-8 md:mb-14 reveal">
        <span class="section-label">What We Do</span>
        <h2 class="text-3xl md:text-5xl font-black mb-4" style="color: var(--color-navy)">
          Expert Craftsmanship,<br/>Every Type of Project
        </h2>
        <p class="text-base max-w-2xl mx-auto" style="color: var(--color-body-text)">
          From a single bathroom refresh to a complete custom home build — we bring the same structured process, clear communication, and uncompromising standards to every project.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service, i) => (
          <a href={service.href} class="card-premium group block p-5 md:p-7 reveal" style={`animation-delay: ${i * 0.08}s`}>
            <div class="flex items-start justify-between mb-4">
              <div class="w-12 h-12 rounded-lg flex items-center justify-center" style="background: rgba(60,225,225,0.1); border: 1px solid rgba(60,225,225,0.2)">
                <svg class="w-6 h-6" style="color: var(--color-cyan-mid)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={service.iconPath}/>
                </svg>
              </div>
              <span class="text-xs font-bold tracking-widest uppercase px-2.5 py-1 rounded-full" style="background: rgba(13,27,42,0.06); color: var(--color-navy); font-family: var(--font-heading)">
                {service.stat}
              </span>
            </div>
            <h3 class="text-xl font-bold mb-3 group-hover:text-cyan-mid transition-colors" style="color: var(--color-navy); font-family: var(--font-heading)">
              {service.title}
            </h3>
            <p class="text-sm leading-relaxed mb-5" style="color: var(--color-body-text)">
              {service.description}
            </p>
            <div class="flex items-center gap-2 text-sm font-semibold" style="color: var(--color-cyan-mid); font-family: var(--font-heading)">
              Learn More
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       PROJECT ESTIMATOR — unique interactive widget
       ═══════════════════════════════════════════════════════ -->
  <section class="section-padding" style="background: var(--color-off-white)">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
        <!-- Left: copy -->
        <div class="reveal-left">
          <span class="section-label">Transparent Pricing</span>
          <h2 class="text-3xl md:text-4xl font-black mb-4 leading-tight" style="color: var(--color-navy)">
            What Will Your<br/>Project Cost?
          </h2>
          <div class="divider-cyan"></div>
          <p class="text-base mb-6 leading-relaxed" style="color: var(--color-body-text)">
            Most contractors make you wait weeks for a number. We believe in transparency from day one. Use our estimator to get a realistic ballpark — then let us give you a precise, itemized estimate at no cost.
          </p>
          <div class="flex flex-col gap-4 mb-8">
            {[
              { label: 'No vague answers', desc: 'Real ranges based on current Utah market conditions.' },
              { label: 'No bait-and-switch', desc: 'Our estimates match our final invoices. Always.' },
              { label: 'Free precise estimate', desc: 'After a site visit, you get a fully itemized written quote.' },
            ].map((item) => (
              <div class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" style="background: rgba(60,225,225,0.15); border: 1px solid var(--color-cyan)">
                  <svg class="w-3 h-3" style="color: var(--color-cyan)" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                </div>
                <div>
                  <span class="font-bold text-sm" style="color: var(--color-navy); font-family: var(--font-heading)">{item.label}</span>
                  <span class="text-sm ml-1" style="color: var(--color-body-text)">— {item.desc}</span>
                </div>
              </div>
            ))}
          </div>
          <a href="/pricing" class="btn-secondary">
            View Full Pricing Guide
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>

        <!-- Right: interactive estimator widget -->
        <div class="reveal-right">
          <ProjectEstimator client:visible />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       COMMITMENTS — dark navy bg, white text, cyan accents
       ═══════════════════════════════════════════════════════ -->
  <section class="section-padding" style="background: var(--color-navy)">
    <div class="container-site">
      <div class="text-center mb-8 md:mb-14 reveal">
        <span class="section-label-light">The Pure Logic Standard</span>
        <h2 class="text-3xl md:text-5xl font-black mb-4" style="color: white">
          Four Commitments We Make<br/>on Every Single Project
        </h2>
        <p class="text-base max-w-2xl mx-auto" style="color: rgba(255,255,255,0.65)">
          Most contractors make promises. We make commitments — and we back them with a documented process so you can hold us accountable at every step.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
        {commitments.map((c, i) => (
          <div class="card-dark p-5 md:p-8 reveal" style={`animation-delay: ${i * 0.1}s`}>
            <div class="w-12 h-12 rounded-lg flex items-center justify-center mb-5" style="background: rgba(60,225,225,0.1); border: 1px solid rgba(60,225,225,0.2)">
              <svg class="w-6 h-6" style="color: var(--color-cyan)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={c.iconPath}/>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3" style="color: white; font-family: var(--font-heading)">{c.title}</h3>
            <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.65)">{c.desc}</p>
          </div>
        ))}
      </div>

      <div class="text-center">
        <a href="/process" class="btn-ghost-cyan">
          See Our Full Process
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       INTERACTIVE PROCESS TIMELINE — dark navy, interactive
       ═══════════════════════════════════════════════════════ -->
  <section class="section-padding" style="background: var(--color-navy-mid)">
    <div class="container-site">
      <div class="text-center mb-8 md:mb-14 reveal">
        <span class="section-label-light">How It Works</span>
        <h2 class="text-3xl md:text-5xl font-black mb-4" style="color: white">
          Our 6-Step Process
        </h2>
        <p class="text-base max-w-2xl mx-auto" style="color: rgba(255,255,255,0.60)">
          Click each step to explore what happens at every stage of your project.
        </p>
      </div>

      <ProcessTimeline client:visible />

      <div class="text-center mt-12">
        <a href="/process" class="btn-primary">
          See the Full Process
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       SERVICE AREA BANNER — off-white bg, dark text
       ═══════════════════════════════════════════════════════ -->
  <section class="section-padding-sm" style="background: var(--color-off-white); border-top: 1px solid var(--color-warm-gray)">
    <div class="container-site text-center reveal">
      <span class="section-label">Service Area</span>
      <h3 class="text-2xl font-bold mb-3" style="color: var(--color-navy)">Serving the Wasatch Front</h3>
      <p class="text-base mb-6" style="color: var(--color-body-text)">
        Ogden · Salt Lake City · Provo · Lehi · Draper · Sandy · Park City · Tooele · and everywhere in between
      </p>
      <a href="/service-area" class="btn-secondary">
        View Full Service Area
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       FINAL CTA — navy bg, white text, cyan buttons
       ═══════════════════════════════════════════════════════ -->
  <section class="section-padding" style="background: var(--color-navy)">
    <div class="container-site text-center reveal">
      <span class="section-label-light">Ready to Start?</span>
