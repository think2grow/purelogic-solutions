---
const services = [
  { href: '/services/kitchen-remodeling', label: 'Kitchen Remodeling' },
  { href: '/services/bathroom-remodeling', label: 'Bathroom Remodeling' },
  { href: '/services/basement-finishing', label: 'Basement Finishing' },
  { href: '/services/home-additions', label: 'Home Additions' },
  { href: '/services/custom-homes', label: 'Custom Home Builds' },
  { href: '/services/whole-home-remodels', label: 'Whole Home Remodels' },
];

const company = [
  { href: '/about', label: 'About Jared & Our Team' },
  { href: '/process', label: 'Our Process' },
  { href: '/service-area', label: 'Service Area' },
  { href: '/pricing', label: 'Pricing Guide' },
  { href: '/blog', label: 'Blog & Resources' },
  { href: '/faq', label: 'FAQs' },
];
---

<footer style="background: var(--color-navy); border-top: 1px solid rgba(60,225,225,0.12)">
  <!-- Main Footer -->
  <div class="container-site py-10 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12">

      <!-- Brand Column -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center mb-6" aria-label="Pure Logic Solutions — Home">
          <img
            src="/images/pure-logic-logo-cropped.png"
            alt="Pure Logic Solutions"
            class="h-10 w-auto object-contain"
            width="240"
            height="60"
            loading="lazy"
          />
        </a>
        <p class="text-sm leading-relaxed mb-6" style="color: rgba(255,255,255,0.65)">
          Premium home remodeling and general contracting across the Wasatch Front. We build it like it's our own.
        </p>
        <!-- Social Links -->
        <div class="flex items-center gap-3">
          <a href="https://www.facebook.com/profile.php?id=61587278352930" target="_blank" rel="noopener" aria-label="Facebook"
            class="w-9 h-9 rounded-full flex items-center justify-center transition-all duration-200"
            style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12)"
            onmouseover="this.style.background='rgba(60,225,225,0.15)'; this.style.borderColor='rgba(60,225,225,0.4)'"
            onmouseout="this.style.background='rgba(255,255,255,0.08)'; this.style.borderColor='rgba(255,255,255,0.12)'">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        </div>
      </div>

      <!-- Services Column -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest mb-5" style="color: var(--color-cyan); font-family: var(--font-heading)">Services</h3>
        <ul class="flex flex-col gap-3">
          {services.map((s) => (
            <li>
              <a href={s.href} class="text-sm transition-colors hover:text-white" style="color: rgba(255,255,255,0.60)">
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company Column -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest mb-5" style="color: var(--color-cyan); font-family: var(--font-heading)">Company</h3>
        <ul class="flex flex-col gap-3">
          {company.map((c) => (
            <li>
              <a href={c.href} class="text-sm transition-colors hover:text-white" style="color: rgba(255,255,255,0.60)">
                {c.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Column -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest mb-5" style="color: var(--color-cyan); font-family: var(--font-heading)">Contact</h3>
        <ul class="flex flex-col gap-4">
          <li>
            <a href="tel:+18019058175" class="flex items-start gap-3 text-sm group" style="color: rgba(255,255,255,0.65)">
              <svg class="w-4 h-4 mt-0.5 shrink-0" style="color: var(--color-cyan)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              <span class="group-hover:text-white transition-colors">(801) 905-8175</span>
            </a>
          </li>
          <li>
            <a href="mailto:Purelogicsolutionsutah@gmail.com" class="flex items-start gap-3 text-sm group" style="color: rgba(255,255,255,0.65)">
              <svg class="w-4 h-4 mt-0.5 shrink-0" style="color: var(--color-cyan)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <span class="group-hover:text-white transition-colors break-all">Purelogicsolutionsutah@gmail.com</span>
            </a>
          </li>
          <li class="flex items-start gap-3 text-sm" style="color: rgba(255,255,255,0.65)">
            <svg class="w-4 h-4 mt-0.5 shrink-0" style="color: var(--color-cyan)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <div>
              <div>Mon–Fri: 7:00 AM – 6:00 PM</div>
              <div>Saturday: 8:00 AM – 4:00 PM</div>
              <div>Sunday: Closed</div>
            </div>
          </li>
          <li class="flex items-start gap-3 text-sm" style="color: rgba(255,255,255,0.65)">
            <svg class="w-4 h-4 mt-0.5 shrink-0" style="color: var(--color-cyan)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span>Serving Ogden to Santaquin,<br/>Tooele to Park City, UT</span>
          </li>
        </ul>
        <div class="mt-6">
          <a href="/contact" class="btn-primary text-xs w-full justify-center">
            Get a Free Estimate
          </a>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom Bar -->
  <div style="border-top: 1px solid rgba(255,255,255,0.08)">
    <div class="container-site py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs" style="color: rgba(255,255,255,0.35)">
        &copy; {new Date().getFullYear()} Pure Logic Solutions. All rights reserved. Utah License #14253923-5501
      </p>
      <div class="flex items-center gap-4 text-xs" style="color: rgba(255,255,255,0.35)">
        <a href="/privacy-policy" class="hover:text-white transition-colors">Privacy Policy</a>
        <span style="color: rgba(255,255,255,0.2)">·</span>
        <a href="/terms" class="hover:text-white transition-colors">Terms of Service</a>
        <span style="color: rgba(255,255,255,0.2)">·</span>
        <a href="https://secure.utah.gov/llv/search/index.html" target="_blank" rel="noopener" class="hover:text-white transition-colors">Verify License</a>
      </div>
    </div>
  </div>
</footer>
