---
import BaseLayout from '../layouts/BaseLayout.astro';
import MagneticButton from '../components/ui/MagneticButton.tsx';

const values = [
  { title: 'Integrity Over Everything', description: 'We will never recommend a material, method, or subcontractor we would not use in our own home. That is not a marketing line — it is the filter every decision runs through.', iconPath: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
  { title: 'Transparency by Default', description: 'Itemized estimates. Written change orders. Regular project updates. We operate as if you can see everything — because you should be able to.', iconPath: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z' },
  { title: 'Systems, Not Guesswork', description: 'Every project follows the same documented process. This is not bureaucracy — it is how we protect your timeline, your budget, and your sanity.', iconPath: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4' },
  { title: 'Your Home, Our Responsibility', description: 'We treat every home we work in as if it belongs to our family. Daily cleanup, protective measures, and a genuine respect for your space are non-negotiable.', iconPath: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
];
---

<BaseLayout
  title="About Jared Bayless & Pure Logic Solutions | Utah General Contractor"
  description="Meet Jared Bayless, founder of Pure Logic Solutions. A Utah husband, father, and builder committed to integrity, transparency, and premium craftsmanship on every project."
>

  <!-- PAGE HERO -->
  <section class="relative py-16 md:py-32 overflow-hidden" style="background: var(--color-navy)">
    <div class="absolute inset-0 z-0 opacity-15">
      <img src="/images/about-hero.jpg" alt="" class="w-full h-full object-cover" loading="lazy" />
    </div>
    <div class="absolute inset-0 z-0" style="background: linear-gradient(135deg, rgba(13,27,42,0.95) 0%, rgba(13,27,42,0.75) 100%)"></div>
    <div class="container-site relative z-10">
      <div class="max-w-2xl">
        <span class="section-label-light">About Pure Logic Solutions</span>
        <h1 class="text-4xl md:text-6xl font-black text-white mb-6 leading-tight">Built on the Question<br/><span style="color: var(--color-cyan)">"Would We Put It In Our House?"</span></h1>
        <p class="text-lg leading-relaxed" style="color: rgba(255,255,255,0.75)">Pure Logic Solutions is not the biggest contractor in Utah. We are the one that shows up, communicates clearly, and delivers exactly what we promise — every time.</p>
      </div>
    </div>
  </section>

  <!-- JARED'S STORY -->
  <section class="section-padding" style="background: var(--color-off-white)">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-start">
        <div class="reveal-left">
          <span class="section-label">The Founder</span>
          <h2 class="text-3xl md:text-4xl font-black mb-4 leading-tight" style="color: var(--color-navy)">Jared Bayless — Husband, Father, Builder</h2>
          <div class="divider-cyan"></div>
          <div class="flex flex-col gap-5 text-base leading-relaxed" style="color: var(--color-body-text)">
            <p>Jared Bayless started Pure Logic Solutions because he kept seeing the same problem: homeowners being let down by contractors who overpromised, underdelivered, and disappeared the moment things got complicated.</p>
            <p>As a husband and father of three living right here on the Wasatch Front, Jared knows what it means to trust someone with your home. He built Pure Logic Solutions on the principle that construction does not have to be stressful, opaque, or unpredictable.</p>
            <p>His background spans residential remodeling, new construction, and project management — giving him the technical depth to solve problems and the communication skills to keep clients informed every step of the way.</p>
            <p>When Jared is not on a job site, he is at home with his family in Utah — which is exactly why he understands the weight of the trust you place in a contractor when you hand over the keys to your home.</p>
          </div>
          <blockquote class="mt-8 p-6 rounded-lg border-l-4" style="background: white; border-color: var(--color-cyan); border-left-width: 4px">
            <p class="text-base font-semibold italic mb-3" style="color: var(--color-navy)">"I started this company because I was tired of seeing homeowners get burned. The standard I hold my team to is simple: if we would not put it in our house, we do not put it in yours."</p>
            <p class="text-sm font-bold" style="color: var(--color-cyan-mid); font-family: var(--font-heading)">— Jared Bayless, Founder &amp; Owner</p>
          </blockquote>
        </div>

        <!-- VIDEO EMBED — Real Cloudflare Stream -->
        <div class="reveal-right">
          <div class="lg:sticky lg:top-28">
            <div style="position: relative; padding-top: 56.25%;">
              <iframe
                src="https://customer-dn4rv9s0dbwshimy.cloudflarestream.com/0846b02a586a6598b14f2f59a5822638/iframe?preload=true&poster=https%3A%2F%2Fcustomer-dn4rv9s0dbwshimy.cloudflarestream.com%2F0846b02a586a6598b14f2f59a5822638%2Fthumbnails%2Fthumbnail.jpg%3Ftime%3D19s%26height%3D600"
                loading="lazy"
                style="border: none; position: absolute; top: 0; left: 0; height: 100%; width: 100%;"
                allow="accelerometer; gyroscope; autoplay; encrypted-media; picture-in-picture;"
                allowfullscreen="true"
              ></iframe>
            </div>
            <!-- Trust Signals — white cards, dark text, high contrast -->
            <div class="grid grid-cols-3 gap-4">
              {[
                { label: 'Utah Licensed', value: '#14253923-5501' },
                { label: 'Response Time', value: 'Within 24 Hours' },
                { label: 'Service Area', value: 'Wasatch Front' },
              ].map((item) => (
                <div class="p-4 rounded-lg text-center card-premium">
                  <div class="text-xs font-black mb-1" style="color: var(--color-cyan-mid); font-family: var(--font-heading)">{item.value}</div>
                  <div class="text-xs font-medium" style="color: var(--color-body-text)">{item.label}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- VALUES -->
  <section class="section-padding" style="background: white">
    <div class="container-site">
      <div class="text-center mb-8 md:mb-14 reveal">
        <span class="section-label">What We Stand For</span>
        <h2 class="text-3xl md:text-4xl font-black mb-4" style="color: var(--color-navy)">Our Core Values</h2>
        <p class="text-base max-w-2xl mx-auto" style="color: var(--color-body-text)">These are not aspirational statements. They are the operating principles that every member of our team is held to on every project.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {values.map((value, i) => (
          <div class="flex gap-4 md:gap-6 p-5 md:p-8 rounded-lg reveal card-premium" style={`animation-delay: ${i * 0.1}s`}>
            <div class="w-14 h-14 rounded-lg flex items-center justify-center shrink-0" style="background: rgba(60,225,225,0.1); border: 1px solid rgba(60,225,225,0.2)">
              <svg class="w-7 h-7" style="color: var(--color-cyan-mid)" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={value.iconPath}/></svg>
            </div>
            <div>
              <h3 class="text-lg font-bold mb-2" style="color: var(--color-navy); font-family: var(--font-heading)">{value.title}</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-body-text)">{value.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY NOT THE CHEAPEST — navy bg, white text, cyan accents -->
  <section class="section-padding" style="background: var(--color-navy)">
    <div class="container-site">
      <div class="max-w-3xl mx-auto text-center reveal">
        <span class="section-label-light">An Honest Note</span>
        <h2 class="text-3xl md:text-4xl font-black text-white mb-4 leading-tight">We Are Not the Right Fit for Everyone — and That Is Intentional</h2>
        <div class="divider-cyan mx-auto"></div>
        <p class="text-base mb-5 leading-relaxed" style="color: rgba(255,255,255,0.72)">If your primary goal is the lowest possible bid, Pure Logic Solutions is probably not the right contractor for you. There are plenty of options in Utah that will give you a number that looks great on paper.</p>
        <p class="text-base mb-10 leading-relaxed" style="color: rgba(255,255,255,0.72)">But if you want a contractor who will show up on time, communicate proactively, use quality materials, and stand behind their work — we would love to talk. Our clients are people who value their homes and understand that quality craftsmanship is an investment, not an expense.</p>
        <MagneticButton href="/contact" variant="primary" client:visible>
          Let's See If We're a Good Fit
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </MagneticButton>
      </div>
    </div>
  </section>

</BaseLayout>
