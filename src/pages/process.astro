---
import BaseLayout from '../layouts/BaseLayout.astro';

const steps = [
  {
    number: '01',
    title: 'Discovery Call & Site Visit',
    duration: 'Week 1',
    description: 'Every project begins with a conversation. We want to understand your vision, your priorities, and your timeline before we ever pick up a measuring tape.',
    details: [
      'Free 30-minute discovery call to discuss your project goals and budget range',
      'In-person site visit at your home — we measure, photograph, and assess the space',
      'We ask the questions most contractors skip: How do you use this space? What frustrates you about it now? What does "done right" look like to you?',
      'No pressure, no obligation — just a genuine effort to understand your project',
    ],
    outcome: 'You have a clear sense of whether we are the right fit, and we have everything we need to build an accurate estimate.',
  },
  {
    number: '02',
    title: 'Detailed Estimate & Proposal',
    duration: 'Week 1–2',
    description: 'Within 5–7 business days of the site visit, you receive a fully itemized, written estimate. No vague line items. No "allowances" that balloon later.',
    details: [
      'Line-by-line breakdown of all labor, materials, and subcontractor costs',
      'Multiple options presented where applicable (good / better / best material tiers)',
      'Clear explanation of what is and is not included in the scope',
      'Honest timeline estimate based on current scheduling and project complexity',
    ],
    outcome: 'You have a complete picture of the investment required — with no hidden costs waiting to surprise you.',
  },
  {
    number: '03',
    title: 'Design & Material Selection',
    duration: 'Week 2–4',
    description: 'Once you decide to move forward, we guide you through every material and finish selection. Every choice is documented so nothing is left to interpretation.',
    details: [
      'Guided selection process for all materials: tile, cabinetry, countertops, fixtures, hardware, paint, flooring',
      'We provide recommendations based on durability, aesthetics, and budget — not commission',
      'All selections are documented in a written specification sheet signed by both parties',
      'Design coordination with architects or interior designers if applicable',
    ],
    outcome: 'Every material is selected, documented, and agreed upon before construction begins. Zero ambiguity.',
  },
  {
    number: '04',
    title: 'Contract, Permits & Scheduling',
    duration: 'Week 3–5',
    description: 'We handle all permits, order materials in advance, and lock in your project start date. You do not pay a dollar until everything is in place.',
    details: [
      'Clear, plain-language contract outlining scope, timeline, payment schedule, and warranty terms',
      'We pull all required permits — you never have to navigate the city or county',
      'Materials are ordered and lead times confirmed before your start date is set',
      'All subcontractors are scheduled and briefed on project specifications',
    ],
    outcome: 'Your project is fully planned, permitted, and scheduled. You know exactly when work begins and what to expect.',
  },
  {
    number: '05',
    title: 'Construction & Communication',
    duration: 'Project Duration',
    description: 'Work begins. From day one, you receive regular updates and have a direct line to Jared. No silence. No chasing us down.',
    details: [
      'Daily or weekly progress updates via your preferred method (text, email, or call)',
      'Daily job site cleanup — your home is respected throughout the process',
      'Proactive communication about any unexpected conditions or decisions needed',
      'All change orders are documented in writing and approved before work proceeds',
      'Regular quality checks at each phase of construction',
    ],
    outcome: 'Your project progresses on schedule, on budget, and with complete visibility at every step.',
  },
  {
    number: '06',
    title: 'Final Walkthrough & Warranty',
    duration: 'Final Week',
    description: 'We do not call a project done until you do. The final walkthrough is thorough, and every punch-list item is resolved before we consider the job complete.',
    details: [
      'Comprehensive final walkthrough with Jared — we go through every inch together',
      'All punch-list items are documented and resolved within an agreed timeframe',
      'Full cleanup and removal of all construction debris and materials',
      'Written warranty documentation provided for all workmanship',
      'Manufacturer warranty documentation for all installed products',
    ],
    outcome: 'You receive a finished project you are proud of, backed by written warranties and a team that stands behind their work.',
  },
];
---

<BaseLayout
  title="Our 6-Step Process | Pure Logic Solutions Utah Contractor"
  description="Discover how Pure Logic Solutions manages every remodeling project — from discovery call to final walkthrough. A transparent, documented process that protects your timeline and budget."
>

  <!-- PAGE HERO -->
  <section class="relative py-16 md:py-32 overflow-hidden" style="background: var(--color-navy)">
    <div class="absolute inset-0 z-0 opacity-15">
      <img src="/images/process-hero.jpg" alt="" class="w-full h-full object-cover" loading="lazy" />
    </div>
    <div class="container-site relative z-10">
      <div class="max-w-2xl">
        <span class="section-label-light">How We Work</span>
        <h1 class="text-4xl md:text-6xl font-black text-white mb-6 leading-tight">A Process Built to<br/><span style="color: var(--color-cyan)">Protect You</span></h1>
        <p class="text-lg leading-relaxed" style="color: rgba(255,255,255,0.75)">Every Pure Logic project follows the same six steps. Not because we are rigid — but because structure is what separates a smooth remodel from a nightmare.</p>
      </div>
    </div>
  </section>

  <!-- PROCESS INTRO -->
  <section class="py-12" style="background: var(--color-navy)">
    <div class="container-site">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 reveal-stagger">
        {[
          { value: 'Written', label: 'Estimates & Contracts' },
          { value: 'Permitted', label: 'Every Project' },
          { value: 'Documented', label: 'Change Orders' },
          { value: 'Warranted', label: 'All Workmanship' },
        ].map((item) => (
          <div class="text-center">
            <div class="text-2xl font-black text-white mb-1" style="font-family: var(--font-heading)">{item.value}</div>
            <div class="text-sm" style="color: rgba(255,255,255,0.7)">{item.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DETAILED STEPS -->
  <section class="section-padding" style="background: var(--color-off-white)">
    <div class="container-site">
      <div class="max-w-4xl mx-auto">
        {steps.map((step, index) => (
          <div class={`flex gap-4 md:gap-8 mb-10 md:mb-16 reveal`}>
            <!-- Step Number -->
            <div class="flex flex-col items-center">
              <div class="w-12 h-12 md:w-16 md:h-16 rounded-full flex items-center justify-center text-base md:text-xl font-black text-white shrink-0" style="background: var(--color-navy); font-family: var(--font-heading)">
                {step.number}
              </div>
              {index < steps.length - 1 && (
                <div class="w-px flex-1 mt-4" style="background: rgba(60,225,225,0.2); min-height: 3rem"></div>
              )}
            </div>
            <!-- Step Content -->
            <div class="flex-1 pb-8">
              <div class="flex flex-wrap items-center gap-3 mb-3">
                <h2 class="text-2xl font-black" style="color: var(--color-navy); font-family: var(--font-heading)">{step.title}</h2>
                <span class="text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full" style="background: rgba(174,154,100,0.15); color: var(--color-cyan)">{step.duration}</span>
              </div>
              <p class="text-base mb-6 leading-relaxed" style="color: var(--color-body-text)">{step.description}</p>
              <div class="p-4 md:p-6 rounded-lg mb-5" style="background: white; border: 1px solid rgba(60,225,225,0.08)">
                <h3 class="text-sm font-bold uppercase tracking-widest mb-4" style="color: var(--color-cyan-mid)">What This Looks Like</h3>
                <ul class="space-y-3">
                  {step.details.map((detail) => (
                    <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: var(--color-body-text)">
                      <svg class="w-4 h-4 mt-0.5 shrink-0" style="color: var(--color-cyan-mid)" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                      {detail}
                    </li>
                  ))}
                </ul>
              </div>
              <div class="flex items-start gap-3 p-4 rounded-lg" style="background: rgba(174,154,100,0.1); border: 1px solid rgba(174,154,100,0.2)">
                <svg class="w-5 h-5 shrink-0 mt-0.5" style="color: var(--color-cyan)" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <div>
                  <span class="text-xs font-bold uppercase tracking-widest" style="color: var(--color-cyan)">Outcome: </span>
                  <span class="text-sm" style="color: var(--color-navy)">{step.outcome}</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding" style="background: var(--color-navy)">
    <div class="container-site">
      <div class="max-w-2xl mx-auto text-center reveal">
        <span class="section-label-light">Ready to Begin?</span>
        <h2 class="text-3xl md:text-4xl font-black text-white mb-6">Step One Starts With a Call</h2>
        <p class="mb-8 leading-relaxed" style="color: rgba(255,255,255,0.7)">The discovery call is free, no-obligation, and usually takes about 30 minutes. It is the most important conversation we will have — and it sets the tone for everything that follows.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" class="btn-primary px-8 py-4">
            Schedule Your Discovery Call
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="tel:+18019058175" class="btn-ghost-white px-8 py-4">Call (801) 905-8175</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
